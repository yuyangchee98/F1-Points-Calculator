---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
import SeasonNotesSection from '../components/seo/SeasonNotesSection.astro';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 2000 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 2000 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 2000 - Championship Predictor"
  description="F1 points calculator for 2000. Replay Michael Schumacher's first title for Ferrari — the Scuderia's first Drivers' Championship in 21 years — his Suzuka duel with Häkkinen, Jaguar's debut and the Williams-BMW partnership, with our drag-and-drop simulator."
  keywords="F1, Formula 1, 2000 season, Schumacher, Häkkinen, Coulthard, Barrichello, Ferrari, McLaren, Williams, BMW, Jaguar, points calculator, championship predictor, race simulator, F1 standings"
  canonicalPath="/2000"
  ogTitle="F1 Points Calculator 2000 - Championship Predictor"
  ogDescription="Replay Schumacher's first Ferrari title and his Suzuka showdown with Häkkinen with our interactive F1 calculator"
  schemaData={schemaData}
  initialYear={2000}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 2000 Season</h1>

    <p>Explore the 2000 Formula 1 World Championship results and simulate alternative
    standings. Use our drag-and-drop calculator to replay the season Michael Schumacher
    delivered Ferrari's first Drivers' Championship in 21 years, settling a year-long fight
    with Mika Häkkinen at Suzuka, in the classic 10-6-4-3-2-1 points era.</p>

    <h2>2000 F1 Season Highlights</h2>
    <ul>
      <li>17 races — opening at <strong>Australia</strong> and closing at <strong>Sepang, Malaysia</strong></li>
      <li>11 teams, 22 drivers — Ferrari, McLaren-Mercedes, Williams-BMW, Benetton, BAR-Honda, Jordan, Arrows, Sauber-Petronas, the debutant Jaguar and Prost-Peugeot, plus Minardi</li>
      <li><strong>Michael Schumacher wins his third Drivers' Championship</strong> (108 pts) — and his first with Ferrari, ending the Scuderia's 21-year wait for a drivers' title since Jody Scheckter in 1979</li>
      <li><strong>Title decided at the Japanese Grand Prix (round 16)</strong> — Schumacher beat Häkkinen wheel-to-wheel at Suzuka with a race to spare</li>
      <li><strong>Mika Häkkinen P2</strong> (89 pts) and <strong>David Coulthard P3</strong> (73 pts) for McLaren-Mercedes; <strong>Rubens Barrichello P4</strong> (62 pts) for Ferrari</li>
      <li><strong>Ferrari take the Constructors' Championship</strong> (170 pts to McLaren's 162) — their second in a row and the start of a record run of dominance</li>
      <li><strong>Barrichello's first F1 win</strong> — a charge from 18th on the grid to victory in a chaotic, rain-hit German Grand Prix at Hockenheim</li>
      <li><strong>Jaguar's debut season</strong> — Ford rebranded the Stewart team as Jaguar Racing (later sold to become Red Bull Racing)</li>
      <li><strong>The Williams-BMW partnership begins</strong> — BMW's return to F1, with 20-year-old rookie Jenson Button scoring points alongside Ralf Schumacher</li>
      <li><strong>Prost-Peugeot scored zero points</strong> — a dismal final year of the Peugeot engine deal</li>
      <li><strong>Classic 10-6-4-3-2-1 points system</strong> — top six only, used since 1991 and kept through 2002</li>
      <li>No Sprint races, no fastest lap bonus point</li>
    </ul>

    <SeasonNotesSection year={2000} />

    <h2>Other Seasons</h2>
