---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
import SeasonNotesSection from '../components/seo/SeasonNotesSection.astro';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 1983 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 1983 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 1983 - Championship Predictor"
  description="F1 points calculator for 1983. Replay Nelson Piquet's title as the first turbo-powered champion with our drag-and-drop championship simulator."
  keywords="F1, Formula 1, 1983 season, Piquet, Prost, Arnoux, Brabham, BMW turbo, Renault, Ferrari, points calculator, championship predictor, race simulator, F1 standings"
  canonicalPath="/1983"
  ogTitle="F1 Points Calculator 1983 - Championship Predictor"
  ogDescription="Replay Piquet's turbo title over Prost's Renault with our interactive F1 calculator"
  schemaData={schemaData}
  initialYear={1983}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 1983 Season</h1>

    <p>Explore the 1983 Formula 1 World Championship results and simulate alternative
    standings. Use our drag-and-drop calculator to replay Nelson Piquet's second title — the
    first won with turbo power — under the classic 9-6-4-3-2-1 system where only a driver's
    best 11 results counted.</p>

    <h2>1983 F1 Season Highlights</h2>
    <ul>
      <li>15 races — opening in <strong>Brazil (Rio)</strong> and closing at <strong>Kyalami, South Africa</strong></li>
      <li><strong>Nelson Piquet wins his second World Championship</strong> (59 pts) for Brabham-BMW, the <strong>first turbo-powered champion</strong></li>
      <li><strong>Alain Prost P2</strong> (57 pts) for Renault — led for much of the year before a late-season collapse cost him the title by two points</li>
      <li><strong>René Arnoux P3</strong> (49 pts) for Ferrari, with three wins</li>
      <li><strong>Ferrari take the Constructors' Championship</strong> (89 pts to Renault's 79)</li>
      <li><strong>Flat-bottom regulations</strong> introduced — ground-effect skirts banned, accelerating the switch to turbo power</li>
      <li><strong>Season-opening Brazil reshuffle</strong> — Keke Rosberg was disqualified from 2nd for a push start; the finishers behind were not promoted for points</li>
      <li><strong>Classic 9-6-4-3-2-1 points system</strong> — only the top six score, best 11 results count</li>
      <li>No Sprint races, no fastest lap bonus point</li>
    </ul>

    <SeasonNotesSection year={1983} />

