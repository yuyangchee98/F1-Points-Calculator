---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
import SeasonNotesSection from '../components/seo/SeasonNotesSection.astro';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 2005 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 2005 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 2005 - Championship Predictor"
  description="F1 points calculator for 2005. Replay Alonso's first title, the 6-car Indianapolis farce, and the final V10 era with our drag-and-drop simulator."
  keywords="F1, Formula 1, 2005 season, Alonso, Räikkönen, Indianapolis, points calculator, championship predictor, race simulator, F1 standings"
  canonicalPath="/2005"
  ogTitle="F1 Points Calculator 2005 - Championship Predictor"
  ogDescription="Replay Alonso's first World Championship and the chaotic 2005 season with our interactive F1 calculator"
  schemaData={schemaData}
  initialYear={2005}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 2005 Season</h1>

    <p>Explore the 2005 Formula 1 World Championship results and simulate alternative
    standings. Use our drag-and-drop calculator to replay Alonso's title-winning charge,
    Räikkönen's bad-luck year, and one of the strangest race weekends in F1 history at
    Indianapolis.</p>

    <h2>2005 F1 Season Highlights</h2>
    <ul>
      <li>19 races, including the <strong>debut Turkish Grand Prix at Istanbul Park</strong> and the infamous <strong>United States Grand Prix at Indianapolis</strong> — only 6 cars raced after all 14 Michelin runners withdrew on the formation lap over tyre safety concerns</li>
      <li>10 teams, 20 drivers — <strong>Red Bull Racing debuts</strong> (bought Jaguar); <strong>final year for Jordan, Minardi, and independent Sauber</strong> (became Midland/Spyker, Toro Rosso, and BMW Sauber respectively in 2006)</li>
      <li><strong>Fernando Alonso wins his first Drivers' Championship</strong> at Renault (133 pts) over Kimi Räikkönen (112), becoming the youngest F1 World Champion at the time</li>
      <li><strong>Renault wins its first Constructors' Championship</strong></li>
      <li><strong>Michael Schumacher's worst Ferrari season</strong> since 1996 — one win all year, at the 6-car Indianapolis race</li>
      <li><strong>BAR-Honda banned from the Spanish and Monaco GPs</strong> after a hidden secondary fuel tank was found at the San Marino GP</li>
      <li>Last year of the <strong>V10 engine era</strong> — 2.4L V8s arrive in 2006</li>
      <li>Last year of the <strong>mid-race tyre-change ban</strong> — one set of dry tyres per race</li>
      <li>Same 10-8-6-5-4-3-2-1 top-8 points system as 2006/2007/2008/2009</li>
      <li>No Sprint races, no fastest lap bonus point</li>
    </ul>

    <SeasonNotesSection year={2005} />

    <h2>Other Seasons</h2>
    <ul>
      <li><a href="/">Current Season Calculator</a></li>
      <li><a href="/2025">2025 F1 Season</a></li>
      <li><a href="/2024">2024 F1 Season</a></li>
      <li><a href="/2023">2023 F1 Season</a></li>
      <li><a href="/2022">2022 F1 Season</a></li>
      <li><a href="/2021">2021 F1 Season</a></li>
      <li><a href="/2020">2020 F1 Season</a></li>
      <li><a href="/2019">2019 F1 Season</a></li>
      <li><a href="/2018">2018 F1 Season</a></li>
      <li><a href="/2017">2017 F1 Season</a></li>
      <li><a href="/2016">2016 F1 Season</a></li>
      <li><a href="/2015">2015 F1 Season</a></li>
      <li><a href="/2014">2014 F1 Season</a></li>
      <li><a href="/2013">2013 F1 Season</a></li>
      <li><a href="/2012">2012 F1 Season</a></li>
      <li><a href="/2011">2011 F1 Season</a></li>
      <li><a href="/2010">2010 F1 Season</a></li>
      <li><a href="/2009">2009 F1 Season</a></li>
      <li><a href="/2008">2008 F1 Season</a></li>
      <li><a href="/2007">2007 F1 Season</a></li>
      <li><a href="/2006">2006 F1 Season</a></li>
    </ul>

    <p><a href="/about">FAQ & Help Guide</a></p>

    <p style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #666;">
      Created by <a href="https://chyuang.com">Chyuang</a> |
      <a href="https://github.com/yuyangchee98/F1-Points-Calculator">View on GitHub</a>
    </p>
  </div>

  <AppIsland year="2005" client:only="react" />
  <script is:inline>document.getElementById('seo-content').style.display='none';</script>
</BaseLayout>
