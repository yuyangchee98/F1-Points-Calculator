---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 2016 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 2016 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 2016 - Championship Predictor"
  description="F1 points calculator for 2016. Explore Formula 1 race results, calculate driver points, and simulate championship standings with our interactive drag-and-drop tool."
  keywords="F1, Formula 1, 2016 season, points calculator, championship predictor, race simulator, F1 standings, predictions"
  canonicalPath="/2016"
  ogTitle="F1 Points Calculator 2016 - Championship Predictor"
  ogDescription="Predict F1 race results and championship standings with our interactive calculator"
  schemaData={schemaData}
  initialYear={2016}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 2016 Season</h1>

    <p>Explore the 2016 Formula 1 World Championship results and simulate alternative standings.
    Use our drag-and-drop calculator to see how different race outcomes would have affected
    the championship.</p>

    <h2>2016 F1 Season Highlights</h2>
    <ul>
      <li>21 races across 21 countries</li>
      <li>11 teams, 22 drivers (Manor Racing's final season)</li>
      <li>No Sprint races</li>
      <li>No fastest lap bonus point</li>
      <li>Nico Rosberg - World Champion (retired after winning the title)</li>
    </ul>

    <h2>Other Seasons</h2>
    <ul>
      <li><a href="/">Current Season Calculator</a></li>
      <li><a href="/2025">2025 F1 Season</a></li>
      <li><a href="/2024">2024 F1 Season</a></li>
      <li><a href="/2023">2023 F1 Season</a></li>
      <li><a href="/2022">2022 F1 Season</a></li>
      <li><a href="/2021">2021 F1 Season</a></li>
      <li><a href="/2020">2020 F1 Season</a></li>
      <li><a href="/2019">2019 F1 Season</a></li>
      <li><a href="/2018">2018 F1 Season</a></li>
      <li><a href="/2017">2017 F1 Season</a></li>
    </ul>

    <p><a href="/about">FAQ & Help Guide</a></p>

    <p style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #666;">
      Created by <a href="https://chyuang.com">Chyuang</a> |
      <a href="https://github.com/yuyangchee98/F1-Points-Calculator">View on GitHub</a>
    </p>
  </div>

  <AppIsland year="2016" client:only="react" />
  <script is:inline>document.getElementById('seo-content').style.display='none';</script>
</BaseLayout>
