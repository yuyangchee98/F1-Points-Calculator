---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrackResultsIsland from '../../components/tracks/TrackResultsIsland';
import { COUNTRY_CODE_MAP } from '../../utils/constants';
import type { CircuitHistory, CircuitListItem } from '../../types/track';

const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;

// ---------------------------------------------------------------------------
// Which track pages to generate. The system is generic: getStaticPaths pulls the
// full circuit list from the Worker. For this first rollout we render ONLY
// Australia — delete the `.filter(...)` line below to turn on every circuit.
// ---------------------------------------------------------------------------
export async function getStaticPaths() {
  const fallback: CircuitListItem[] = [
    { circuitId: 'albert_park', slug: 'australian-grand-prix', fullName: 'Australian Grand Prix', country: 'Australia' },
  ];

  let circuits: CircuitListItem[] = fallback;
  try {
    const res = await fetch(`${import.meta.env.PUBLIC_API_BASE_URL}/api/circuits`);
    if (res.ok) {
      const data = (await res.json()) as { circuits: CircuitListItem[] };
      if (data.circuits?.length) circuits = data.circuits;
    }
  } catch {
    // Worker unreachable at build — fall back to the Australia entry below.
  }

  return circuits
    .filter((c) => c.circuitId === 'albert_park') // ← remove to enable all tracks
    .map((c) => ({ params: { track: c.slug }, props: c }));
}

const { circuitId, fullName, country } = Astro.props as CircuitListItem;
const slug = Astro.params.track;

// Build-time fetch (unauthenticated): free years full, premium years locked.
let history: CircuitHistory | null = null;
try {
  const res = await fetch(`${API_BASE_URL}/api/circuit?circuitId=${circuitId}`);
  if (res.ok) history = (await res.json()) as CircuitHistory;
} catch {
  history = null;
}

const editions = history?.editions ?? [];
const locality = history?.locality ?? '';
const circuitName = history?.fullName ?? fullName;
const seasons = editions.map((e) => e.season);
const latestSeason = seasons.length ? Math.max(...seasons) : null;
const earliestSeason = seasons.length ? Math.min(...seasons) : null;
const countryCode = COUNTRY_CODE_MAP[country.toLowerCase()] ?? '';

// Aggregate trivia computed server-side over the full history (incl. premium years).
const stats = history?.stats;
const latestEdition = editions.find((e) => e.season === latestSeason);
const latestWinner = latestEdition?.results?.find((p) => p.position === 1);

const title = `${fullName} Winners & Results by Year | F1 Points Calculator`;
const yearRange = earliestSeason && latestSeason ? `${earliestSeason}–${latestSeason}` : '';
const description = `Every ${fullName} winner and podium at ${circuitName}${locality ? `, ${locality}` : ''}. Full Formula 1 results year by year${yearRange ? ` (${yearRange})` : ''}.`;

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  about: {
    '@type': 'Place',
    name: circuitName,
    address: {
      '@type': 'PostalAddress',
      addressLocality: locality,
      addressCountry: country,
    },
  },
};

const driverLabel = (p?: { driverName: string }) => p?.driverName ?? '—';
const podiumAt = (e: typeof editions[number], pos: number) => e.results?.find((p) => p.position === pos);
---

<BaseLayout
  title={title}
  description={description}
  keywords={`${fullName}, ${circuitName}, ${fullName} winners, ${country} grand prix results, F1 podium history, Formula 1 results by year`}
  canonicalPath={`/tracks/${slug}`}
  schemaData={schemaData}
>
  <div class="flex flex-col sm:flex-row h-[100dvh] overflow-hidden text-ink">
    {/* Left sidebar — same shape as the calculator's standings sidebar */}
    <aside class="sm:w-80 sm:min-w-[300px] shrink-0 bg-surface border-r overflow-y-auto">
      <div class="p-4 flex flex-col gap-5">
        <nav class="text-xs text-ink-muted" aria-label="Breadcrumb">
          <a href="/" class="hover:text-ink">Calculator</a>
          <span class="mx-1">/</span>
          <span class="text-ink-secondary">Tracks</span>
        </nav>

        <header>
          <div class="flex items-center gap-2 mb-1.5">
            {countryCode && (
              <img
                src={`https://flagcdn.com/w40/${countryCode}.png`}
                width="28"
                height="21"
                alt={`${country} flag`}
                class="rounded shadow-sm"
                loading="eager"
              />
            )}
            <h1 class="text-xl font-bold font-display tracking-tight leading-tight">{fullName}</h1>
          </div>
          <p class="text-xs text-ink-secondary">{[circuitName, locality, country].filter(Boolean).join(' · ')}</p>
          <p class="text-xs text-ink-muted mt-0.5">Results by year{yearRange ? ` · ${yearRange}` : ''}</p>
        </header>

        {editions.length > 0 && (
          <div class="flex flex-col gap-2">
            {latestWinner && (
              <div class="rounded-lg border bg-surface-sunken p-3">
                <div class="text-2xs uppercase tracking-wide text-ink-muted">Latest winner</div>
                <div class="text-base font-semibold leading-tight">{latestWinner.driverName}</div>
                <div class="text-xs text-ink-muted">{latestSeason} · {latestWinner.teamName}</div>
              </div>
            )}
            {stats?.mostWinsDriver && (
              <div class="rounded-lg border bg-surface-sunken p-3">
                <div class="text-2xs uppercase tracking-wide text-ink-muted">Most wins</div>
                <div class="text-base font-semibold leading-tight">{stats.mostWinsDriver.name}</div>
                <div class="text-xs text-ink-muted">{stats.mostWinsDriver.count} wins</div>
              </div>
            )}
            <div class="grid grid-cols-2 gap-2">
              {stats?.mostPodiumsDriver && (
                <div class="rounded-lg border bg-surface-sunken p-3">
                  <div class="text-2xs uppercase tracking-wide text-ink-muted">Most podiums</div>
                  <div class="text-sm font-semibold leading-tight">{stats.mostPodiumsDriver.name}</div>
                  <div class="text-xs text-ink-muted">{stats.mostPodiumsDriver.count}</div>
                </div>
              )}
              {stats?.mostWinsTeam && (
                <div class="rounded-lg border bg-surface-sunken p-3">
                  <div class="text-2xs uppercase tracking-wide text-ink-muted">Top team</div>
                  <div class="text-sm font-semibold leading-tight">{stats.mostWinsTeam.name}</div>
                  <div class="text-xs text-ink-muted">{stats.mostWinsTeam.count} wins</div>
                </div>
              )}
            </div>
            {stats && (
              <div class="flex gap-2 text-xs text-ink-secondary">
                <span class="rounded-md bg-surface-sunken border px-2 py-1"><strong class="text-ink">{stats.uniqueWinners}</strong> different winners</span>
                <span class="rounded-md bg-surface-sunken border px-2 py-1"><strong class="text-ink">{stats.totalEditions}</strong> races</span>
              </div>
            )}
          </div>
        )}

        <p class="text-xs text-ink-secondary leading-relaxed">
          Every {fullName} at {circuitName}, with the full classification year by year.
          Premium seasons are part of the Archive.
        </p>

        <a
          href="/"
          class="inline-flex items-center justify-center h-10 rounded-md bg-brand text-white font-semibold text-sm hover:opacity-90 transition-opacity"
        >
          Open the Points Calculator
        </a>

        <p class="text-2xs text-ink-muted mt-auto pt-2">Data via the Jolpica/Ergast F1 API.</p>
      </div>
    </aside>

    {/* Main — the results grid, calculator styling, full width */}
    <main class="flex-1 min-h-0 flex flex-col p-2 sm:p-3 bg-surface-sunken">
      {/* Static table — server-rendered for SEO / no-JS. The island replaces it. */}
      <div id="track-results-static" class="flex-1 min-h-0 overflow-auto bg-surface rounded-lg border p-2">
        {editions.length === 0 ? (
          <div class="p-4 text-ink-secondary">Results are temporarily unavailable. Please check back soon.</div>
        ) : (
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-surface-sunken text-left text-ink-muted">
                <th class="px-3 py-2 font-medium">Year</th>
                <th class="px-3 py-2 font-medium">🥇 Winner</th>
                <th class="px-3 py-2 font-medium">🥈 2nd</th>
                <th class="px-3 py-2 font-medium">🥉 3rd</th>
              </tr>
            </thead>
            <tbody>
              {editions.map((e) => (
                <tr class="border-t">
                  <td class="px-3 py-2 font-semibold whitespace-nowrap align-top">{e.season}</td>
                  {e.locked ? (
                    <td class="px-3 py-2 text-ink-muted" colspan="3">
                      🔒 Archive — <a href="/" class="text-brand hover:underline">unlock historical seasons</a>
                    </td>
                  ) : (
                    <>
                      <td class="px-3 py-2 align-top">
                        <div class="font-medium">{driverLabel(podiumAt(e, 1))}</div>
                        <div class="text-xs text-ink-muted">{podiumAt(e, 1)?.teamName}</div>
                      </td>
                      <td class="px-3 py-2 align-top">
                        <div>{driverLabel(podiumAt(e, 2))}</div>
                        <div class="text-xs text-ink-muted">{podiumAt(e, 2)?.teamName}</div>
                      </td>
                      <td class="px-3 py-2 align-top">
                        <div>{driverLabel(podiumAt(e, 3))}</div>
                        <div class="text-xs text-ink-muted">{podiumAt(e, 3)?.teamName}</div>
                      </td>
                    </>
                  )}
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>

      {editions.length > 0 && (
        <div class="flex-1 min-h-0">
          <TrackResultsIsland
            client:only="react"
            circuitId={circuitId}
            initialEditions={editions}
            staticContainerId="track-results-static"
          />
        </div>
      )}
    </main>
  </div>
</BaseLayout>
