---

<BaseLayout
  title="Changelog - F1 Points Calculator"
  description="See what's new in the F1 Points Calculator. Browse the full history of features, improvements, and updates."
  keywords="F1 points calculator changelog, F1 calculator updates, new features, release history"
  canonicalPath="/changelog"
  ogTitle="Changelog - F1 Points Calculator"
  ogDescription="See what's new in the F1 Points Calculator. Full history of features, improvements, and updates."
>
  <div class="min-h-screen bg-surface-sunken py-6">
    <div class="max-w-3xl mx-auto px-4">
      <div class="mb-6">
        <a
          href="/"
          class="inline-flex items-center text-interactive hover:underline font-medium text-sm"
        >
          <svg
            class="w-5 h-5 mr-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
            />
          </svg>
          Back to Calculator
        </a>
      </div>

      <h1 class="text-2xl font-display font-bold text-ink mb-6 flex items-center flex-wrap gap-x-3">
        <span class="bg-brand text-white text-lg px-2.5 py-1 rounded-md font-display font-bold">F1</span>
        <span>Points Calculator</span>
        <span class="text-ink-muted font-semibold">Changelog</span>
      </h1>

      <div class="relative">
        {changelogEntries.map((entry, index) => (
          <div class={`relative pl-8 ${index !== changelogEntries.length - 1 ? 'pb-6' : ''}`}>
            {index !== changelogEntries.length - 1 && (
              <div class="absolute left-[11px] top-8 bottom-0 w-0.5 bg-carbon-200"></div>
            )}
            <div class={`absolute left-1.5 top-2 w-3 h-3 rounded-full ${index === 0 ? 'bg-brand' : 'bg-carbon-300'}`}></div>
            <div class="p-4 bg-surface rounded-lg shadow-xs border">
              <span class="text-sm font-medium text-ink-muted">{entry.date}</span>
              <h2 class="text-lg font-display font-semibold text-ink mt-1 mb-2">{entry.title}</h2>
              <ul class="list-disc list-inside text-ink-secondary space-y-1 text-sm">
                {entry.changes.map((change) => (
                  <li>{change}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
