---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 2010 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 2010 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 2010 - Championship Predictor"
  description="F1 points calculator for 2010. Explore Formula 1 race results, calculate driver points, and simulate championship standings with our interactive drag-and-drop tool."
  keywords="F1, Formula 1, 2010 season, points calculator, championship predictor, race simulator, F1 standings, predictions"
  canonicalPath="/2010"
  ogTitle="F1 Points Calculator 2010 - Championship Predictor"
  ogDescription="Predict F1 race results and championship standings with our interactive calculator"
  schemaData={schemaData}
  initialYear={2010}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 2010 Season</h1>

    <p>Explore the 2010 Formula 1 World Championship results and simulate alternative standings.
    Use our drag-and-drop calculator to see how different race outcomes would have affected
    the championship.</p>

    <h2>2010 F1 Season Highlights</h2>
    <ul>
      <li>19 races, opening in Bahrain and ending at the Abu Dhabi finale</li>
      <li>12 teams, 24 drivers — Mercedes returns as a works team with Michael Schumacher's comeback; Lotus Racing, HRT and Virgin Racing all debut</li>
      <li>First year of the modern 25-18-15 points system, replacing the old 10-8-6 scoring</li>
      <li>No Sprint races</li>
      <li>No fastest lap bonus point</li>
      <li>Sebastian Vettel becomes the youngest F1 World Champion at 23, deciding the title at the Abu Dhabi finale in a three-way fight with Alonso and Webber</li>
      <li>Red Bull Racing's first Constructors' Championship</li>
    </ul>

    <h2>Other Seasons</h2>
    <ul>
      <li><a href="/">Current Season Calculator</a></li>
      <li><a href="/2025">2025 F1 Season</a></li>
      <li><a href="/2024">2024 F1 Season</a></li>
      <li><a href="/2023">2023 F1 Season</a></li>
      <li><a href="/2022">2022 F1 Season</a></li>
      <li><a href="/2021">2021 F1 Season</a></li>
      <li><a href="/2020">2020 F1 Season</a></li>
      <li><a href="/2019">2019 F1 Season</a></li>
      <li><a href="/2018">2018 F1 Season</a></li>
      <li><a href="/2017">2017 F1 Season</a></li>
      <li><a href="/2016">2016 F1 Season</a></li>
      <li><a href="/2015">2015 F1 Season</a></li>
      <li><a href="/2014">2014 F1 Season</a></li>
      <li><a href="/2013">2013 F1 Season</a></li>
      <li><a href="/2012">2012 F1 Season</a></li>
      <li><a href="/2011">2011 F1 Season</a></li>
      <li><a href="/2009">2009 F1 Season</a></li>
      <li><a href="/2008">2008 F1 Season</a></li>
      <li><a href="/2007">2007 F1 Season</a></li>
      <li><a href="/2006">2006 F1 Season</a></li>
      <li><a href="/2005">2005 F1 Season</a></li>
      <li><a href="/2004">2004 F1 Season</a></li>
      <li><a href="/2003">2003 F1 Season</a></li>
    </ul>

    <p><a href="/about">FAQ & Help Guide</a></p>

    <p style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #666;">
      Created by <a href="https://chyuang.com">Chyuang</a> |
      <a href="https://github.com/yuyangchee98/F1-Points-Calculator">View on GitHub</a>
    </p>
  </div>

  <AppIsland year="2010" client:only="react" />
  <script is:inline>document.getElementById('seo-content').style.display='none';</script>
</BaseLayout>
