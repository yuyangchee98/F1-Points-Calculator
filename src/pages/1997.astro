---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
import SeasonNotesSection from '../components/seo/SeasonNotesSection.astro';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 1997 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 1997 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 1997 - Championship Predictor"
  description="F1 points calculator for 1997. Replay Jacques Villeneuve's title and the Jerez finale where Michael Schumacher was disqualified from the championship, with our drag-and-drop simulator."
  keywords="F1, Formula 1, 1997 season, Villeneuve, Schumacher, Frentzen, Williams, Ferrari, Jerez, disqualified, points calculator, championship predictor, race simulator, F1 standings"
  canonicalPath="/1997"
  ogTitle="F1 Points Calculator 1997 - Championship Predictor"
  ogDescription="Replay Villeneuve's title and the Jerez decider where Schumacher was excluded, with our interactive F1 calculator"
  schemaData={schemaData}
  initialYear={1997}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 1997 Season</h1>

    <p>Explore the 1997 Formula 1 World Championship results and simulate alternative
    standings. Use our drag-and-drop calculator to replay Jacques Villeneuve's title for
    Williams-Renault and the explosive Jerez finale — where Michael Schumacher was
    disqualified from the entire championship — in the classic 10-6-4-3-2-1 points era.</p>

    <h2>1997 F1 Season Highlights</h2>
    <ul>
      <li>17 races — opening at <strong>Melbourne, Australia</strong> and closing at <strong>Jerez, Spain</strong> (the European GP)</li>
      <li><strong>Jacques Villeneuve wins the World Championship</strong> (81 pts, 7 wins) for Williams-Renault in his second season</li>
      <li><strong>Michael Schumacher disqualified from the championship</strong> — after deliberately turning into Villeneuve at the Jerez decider, he was excluded from the standings despite scoring 78 points on track (he keeps his race results, so Ferrari retain their Constructors' points)</li>
      <li><strong>Heinz-Harald Frentzen P2</strong> (42 pts) in his first year replacing Damon Hill at Williams, winning at Imola</li>
      <li><strong>David Coulthard P3</strong> (36 pts) helped the new silver West McLaren-Mercedes back to winning ways</li>
      <li><strong>Williams-Renault take the Constructors' Championship</strong> (123 pts to Ferrari's 102)</li>
      <li><strong>Stewart Grand Prix debut</strong> — Rubens Barrichello took a shock P2 in the wet at Monaco in only the team's fifth race; the failed MasterCard Lola folded after a single weekend</li>
      <li><strong>Tyre war returns</strong> — Bridgestone entered to challenge Goodyear, and McLaren's Mika Häkkinen took his maiden win at the Jerez finale</li>
      <li><strong>Classic 10-6-4-3-2-1 points system</strong> — only the top six score</li>
      <li>No Sprint races, no fastest lap bonus point</li>
    </ul>

    <SeasonNotesSection year={1997} />

