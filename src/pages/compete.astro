---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompeteIsland from '../components/CompeteIsland';
---

<BaseLayout
  title="F1 Predictions Competition - Lock Predictions & Compete"
  description="Compete against other F1 fans by locking in your race predictions before each Grand Prix. Get scored on accuracy and climb the leaderboard."
  keywords="F1 predictions, F1 competition, Formula 1 predictions leaderboard, F1 prediction accuracy, lock F1 predictions"
  canonicalPath="/compete"
  ogTitle="F1 Predictions Competition - Lock Predictions & Compete"
  ogDescription="Compete against other F1 fans by locking in your race predictions before each Grand Prix."
>
  <CompeteIsland client:only="react" />

  <noscript>
    <div style="padding: 20px; background: #f3f4f6;">
      <h1>F1 Predictions Competition</h1>
      <p>Lock in your race predictions before each Grand Prix, get scored on accuracy, and compete against other F1 fans on the leaderboard.</p>

      <h2>How it works:</h2>
      <ul>
        <li>Drag and drop drivers to predict race finishing positions</li>
        <li>Lock your predictions before the race starts</li>
        <li>Get scored based on prediction accuracy</li>
        <li>Climb the leaderboard and compete with others</li>
      </ul>

      <p>This application requires JavaScript to run. Please enable JavaScript to use the interactive features.</p>

      <ul>
        <li><a href="/" rel="noopener">Back to Calculator</a></li>
        <li><a href="/leaderboard" rel="noopener">View Leaderboard</a></li>
      </ul>
    </div>
  </noscript>
</BaseLayout>
