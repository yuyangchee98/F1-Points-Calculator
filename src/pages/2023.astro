---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';

const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 2023 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 2023 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 2023 - Championship Predictor"
  description="F1 points calculator for 2023. Explore Formula 1 race results, calculate driver points, and simulate championship standings with our interactive drag-and-drop tool."
  keywords="F1, Formula 1, 2023 season, points calculator, championship predictor, race simulator, F1 standings, predictions"
  canonicalPath="/2023"
  ogTitle="F1 Points Calculator 2023 - Championship Predictor"
  ogDescription="Predict F1 race results and championship standings with our interactive calculator"
  schemaData={schemaData}
  initialYear={2023}
>
  <AppIsland year="2023" client:only="react" />

  <noscript>
    <div style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
      <h1 style="color: #dc2626;">F1 Points Calculator - 2023 Season</h1>

      <p>Explore the 2023 Formula 1 World Championship results and simulate alternative standings.
      Use our drag-and-drop calculator to see how different race outcomes would have affected
      the championship.</p>

      <h2>2023 F1 Season Highlights</h2>
      <ul>
        <li>22 races across 20 countries</li>
        <li>6 Sprint race weekends</li>
        <li>Max Verstappen - World Champion</li>
      </ul>

      <h2>Other Seasons</h2>
      <ul>
        <li><a href="/">Current Season Calculator</a></li>
        <li><a href="/2024">2024 F1 Season</a></li>
        <li><a href="/2022">2022 F1 Season</a></li>
      </ul>

      <h2>2023 Race Results</h2>
      <ul>
        <li><a href="/race/2023/bahrain">Bahrain GP</a></li>
        <li><a href="/race/2023/saudi-arabian">Saudi Arabian GP</a></li>
        <li><a href="/race/2023/australian">Australian GP</a></li>
        <li><a href="/race/2023/azerbaijan-sprint">Azerbaijan GP Sprint</a></li>
        <li><a href="/race/2023/azerbaijan">Azerbaijan GP</a></li>
        <li><a href="/race/2023/miami">Miami GP</a></li>
        <li><a href="/race/2023/monaco">Monaco GP</a></li>
        <li><a href="/race/2023/spanish">Spanish GP</a></li>
        <li><a href="/race/2023/canadian">Canadian GP</a></li>
        <li><a href="/race/2023/austrian-sprint">Austrian GP Sprint</a></li>
        <li><a href="/race/2023/austrian">Austrian GP</a></li>
        <li><a href="/race/2023/british">British GP</a></li>
        <li><a href="/race/2023/hungarian">Hungarian GP</a></li>
        <li><a href="/race/2023/belgian-sprint">Belgian GP Sprint</a></li>
        <li><a href="/race/2023/belgian">Belgian GP</a></li>
        <li><a href="/race/2023/dutch">Dutch GP</a></li>
        <li><a href="/race/2023/italian">Italian GP</a></li>
        <li><a href="/race/2023/singapore">Singapore GP</a></li>
        <li><a href="/race/2023/japanese">Japanese GP</a></li>
        <li><a href="/race/2023/qatar-sprint">Qatar GP Sprint</a></li>
        <li><a href="/race/2023/qatar">Qatar GP</a></li>
        <li><a href="/race/2023/united-states-sprint">United States GP Sprint</a></li>
        <li><a href="/race/2023/united-states">United States GP</a></li>
        <li><a href="/race/2023/mexico-city">Mexico City GP</a></li>
        <li><a href="/race/2023/são-paulo-sprint">São Paulo GP Sprint</a></li>
        <li><a href="/race/2023/são-paulo">São Paulo GP</a></li>
        <li><a href="/race/2023/las-vegas">Las Vegas GP</a></li>
        <li><a href="/race/2023/abu-dhabi">Abu Dhabi GP</a></li>
      </ul>

      <p><a href="/about">FAQ & Help Guide</a></p>

      <p style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #666;">
