---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
import SeasonNotesSection from '../components/seo/SeasonNotesSection.astro';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 2009 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 2009 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 2009 - Championship Predictor"
  description="F1 points calculator for 2009. Explore the Brawn GP fairy-tale season, calculate driver points using the original 10-8-6 system, and simulate championship standings."
  keywords="F1, Formula 1, 2009 season, Brawn GP, points calculator, championship predictor, race simulator, F1 standings, predictions"
  canonicalPath="/2009"
  ogTitle="F1 Points Calculator 2009 - Championship Predictor"
  ogDescription="Replay the Brawn GP fairy tale with our interactive 2009 F1 calculator"
  schemaData={schemaData}
  initialYear={2009}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 2009 Season</h1>

    <p>Explore the 2009 Formula 1 World Championship results and simulate alternative
    standings. Use our drag-and-drop calculator to see how different race outcomes
    would have shaped the season.</p>

    <h2>2009 F1 Season Highlights</h2>
    <ul>
      <li>17 races, opening in Australia and ending at the first-ever Abu Dhabi Grand Prix</li>
      <li>10 teams, 20 drivers — last season for BMW Sauber, Toyota and Brawn GP</li>
      <li><strong>Brawn GP's fairy-tale title</strong>: Honda walked away from F1 in late 2008; Ross Brawn bought the team for £1 and turned it into Constructors' Champion with a controversial double-diffuser design</li>
      <li>Jenson Button wins the Drivers' Championship after taking 6 of the first 7 races</li>
      <li>Sebastian Vettel emerges as Red Bull's title contender with 4 race wins</li>
      <li>The final year of the original 10-8-6-5-4-3-2-1 top-8 points system before F1's 25-18-15 overhaul</li>
      <li>No Sprint races, no fastest lap bonus point</li>
    </ul>

    <SeasonNotesSection year={2009} />

    <h2>Other Seasons</h2>
    <ul>
      <li><a href="/">Current Season Calculator</a></li>
      <li><a href="/2025">2025 F1 Season</a></li>
      <li><a href="/2024">2024 F1 Season</a></li>
      <li><a href="/2023">2023 F1 Season</a></li>
      <li><a href="/2022">2022 F1 Season</a></li>
      <li><a href="/2021">2021 F1 Season</a></li>
      <li><a href="/2020">2020 F1 Season</a></li>
      <li><a href="/2019">2019 F1 Season</a></li>
      <li><a href="/2018">2018 F1 Season</a></li>
      <li><a href="/2017">2017 F1 Season</a></li>
      <li><a href="/2016">2016 F1 Season</a></li>
      <li><a href="/2015">2015 F1 Season</a></li>
      <li><a href="/2014">2014 F1 Season</a></li>
      <li><a href="/2013">2013 F1 Season</a></li>
      <li><a href="/2012">2012 F1 Season</a></li>
      <li><a href="/2011">2011 F1 Season</a></li>
      <li><a href="/2010">2010 F1 Season</a></li>
      <li><a href="/2008">2008 F1 Season</a></li>
      <li><a href="/2007">2007 F1 Season</a></li>
      <li><a href="/2006">2006 F1 Season</a></li>
      <li><a href="/2005">2005 F1 Season</a></li>
      <li><a href="/2004">2004 F1 Season</a></li>
      <li><a href="/2003">2003 F1 Season</a></li>
      <li><a href="/2002">2002 F1 Season</a></li>
      <li><a href="/2001">2001 F1 Season</a></li>
    </ul>

    <p><a href="/about">FAQ & Help Guide</a></p>

    <p style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #666;">
      Created by <a href="https://chyuang.com">Chyuang</a> |
      <a href="https://github.com/yuyangchee98/F1-Points-Calculator">View on GitHub</a>
    </p>
  </div>

  <AppIsland year="2009" client:only="react" />
  <script is:inline>document.getElementById('seo-content').style.display='none';</script>
</BaseLayout>
