---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
import SeasonNotesSection from '../components/seo/SeasonNotesSection.astro';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 2004 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 2004 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 2004 - Championship Predictor"
  description="F1 points calculator for 2004. Replay Schumacher's seventh and final title, Ferrari's dominant 15-win season, and the debut Bahrain and China GPs with our drag-and-drop simulator."
  keywords="F1, Formula 1, 2004 season, Schumacher, Ferrari, Bahrain, China, points calculator, championship predictor, race simulator, F1 standings"
  canonicalPath="/2004"
  ogTitle="F1 Points Calculator 2004 - Championship Predictor"
  ogDescription="Replay Michael Schumacher's record-breaking 13-win 2004 season with our interactive F1 calculator"
  schemaData={schemaData}
  initialYear={2004}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 2004 Season</h1>

    <p>Explore the 2004 Formula 1 World Championship results and simulate alternative
    standings. Use our drag-and-drop calculator to replay Schumacher's seventh and final
    title, Ferrari's near-total dominance, and the debut of two new continents on the
    calendar.</p>

    <h2>2004 F1 Season Highlights</h2>
    <ul>
      <li>18 races, including the <strong>debut Bahrain Grand Prix at Sakhir</strong> and the <strong>debut Chinese Grand Prix at Shanghai</strong> — F1's first races in the Middle East and mainland Asia</li>
      <li>10 teams, 20 drivers — <strong>final season for Jaguar Racing</strong> (sold to Red Bull) and the original <strong>Jordan Grand Prix in its independent form</strong> (sold to Midland after 2005)</li>
      <li><strong>Michael Schumacher wins his seventh and final Drivers' Championship</strong> with Ferrari (148 pts) — a then-record 13 wins from 18 starts, sealing the title with six races to spare at Spa</li>
      <li><strong>Ferrari's sixth consecutive Constructors' Championship</strong> — 262 points to BAR-Honda's 119, with Ferrari winning 15 of 18 races</li>
      <li><strong>Rubens Barrichello P2 in the championship</strong> (114 pts) — second straight Ferrari 1-2</li>
      <li><strong>BAR-Honda's breakthrough year</strong> — Jenson Button P3 in the standings (85 pts), the team's best-ever finish</li>
      <li><strong>Jarno Trulli's first F1 win</strong> at Monaco for Renault</li>
      <li><strong>Kimi Räikkönen's win at Spa</strong> — McLaren's only victory in a difficult MP4-19 year</li>
      <li>Same 10-8-6-5-4-3-2-1 top-8 points system as 2003 and 2005-2009</li>
      <li>One-engine-per-weekend rule — engines had to last a full race weekend (extended to two weekends from 2005)</li>
      <li>No Sprint races, no fastest lap bonus point</li>
    </ul>

    <SeasonNotesSection year={2004} />

    <h2>Other Seasons</h2>
    <ul>
      <li><a href="/">Current Season Calculator</a></li>
      <li><a href="/2025">2025 F1 Season</a></li>
      <li><a href="/2024">2024 F1 Season</a></li>
      <li><a href="/2023">2023 F1 Season</a></li>
      <li><a href="/2022">2022 F1 Season</a></li>
      <li><a href="/2021">2021 F1 Season</a></li>
      <li><a href="/2020">2020 F1 Season</a></li>
      <li><a href="/2019">2019 F1 Season</a></li>
      <li><a href="/2018">2018 F1 Season</a></li>
      <li><a href="/2017">2017 F1 Season</a></li>
      <li><a href="/2016">2016 F1 Season</a></li>
      <li><a href="/2015">2015 F1 Season</a></li>
      <li><a href="/2014">2014 F1 Season</a></li>
      <li><a href="/2013">2013 F1 Season</a></li>
      <li><a href="/2012">2012 F1 Season</a></li>
      <li><a href="/2011">2011 F1 Season</a></li>
      <li><a href="/2010">2010 F1 Season</a></li>
      <li><a href="/2009">2009 F1 Season</a></li>
      <li><a href="/2008">2008 F1 Season</a></li>
      <li><a href="/2007">2007 F1 Season</a></li>
      <li><a href="/2006">2006 F1 Season</a></li>
      <li><a href="/2005">2005 F1 Season</a></li>
      <li><a href="/2003">2003 F1 Season</a></li>
      <li><a href="/2002">2002 F1 Season</a></li>
      <li><a href="/2001">2001 F1 Season</a></li>
    </ul>

    <p><a href="/about">FAQ & Help Guide</a></p>

    <p style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #666;">
      Created by <a href="https://chyuang.com">Chyuang</a> |
      <a href="https://github.com/yuyangchee98/F1-Points-Calculator">View on GitHub</a>
    </p>
  </div>

  <AppIsland year="2004" client:only="react" />
  <script is:inline>document.getElementById('seo-content').style.display='none';</script>
</BaseLayout>
