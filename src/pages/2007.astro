---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 2007 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 2007 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 2007 - Championship Predictor"
  description="F1 points calculator for 2007. Replay Räikkönen's one-point title win over Hamilton and Alonso, calculate driver points using the 10-8-6 system, and simulate alternative standings."
  keywords="F1, Formula 1, 2007 season, Räikkönen, Hamilton, Alonso, points calculator, championship predictor, race simulator, F1 standings, predictions"
  canonicalPath="/2007"
  ogTitle="F1 Points Calculator 2007 - Championship Predictor"
  ogDescription="Replay Räikkönen's one-point title win over Hamilton with our interactive 2007 F1 calculator"
  schemaData={schemaData}
  initialYear={2007}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 2007 Season</h1>

    <p>Explore the 2007 Formula 1 World Championship results and simulate alternative
    standings. Use our drag-and-drop calculator to see how one of the tightest three-way
    title fights in F1 history could have gone differently.</p>

    <h2>2007 F1 Season Highlights</h2>
    <ul>
      <li>17 races, opening in Australia and ending in Brazil — the final F1 race at Indianapolis until the United States returned to the calendar in the modern Miami/Austin era</li>
      <li>11 teams, 22 drivers — Super Aguri and Spyker still on the grid; Toro Rosso in only its second year</li>
      <li><strong>Kimi Räikkönen wins the World Championship by 1 point</strong> — 110 to Hamilton's 109 and Alonso's 109, decided at the Brazil finale where Räikkönen won the race in his first season at Ferrari</li>
      <li><strong>Lewis Hamilton's rookie season</strong> — nine podiums in his first nine races; led the championship into the final round before losing it on countback</li>
      <li><strong>"Spygate"</strong> — McLaren stripped of all Constructors' points after the Ferrari technical-data scandal; Ferrari take the Constructors' title</li>
      <li>Bridgestone single-tyre supplier era begins (Michelin exited at the end of 2006)</li>
      <li>Same 10-8-6-5-4-3-2-1 top-8 points system as 2008 and 2009 — the pre-25-18-15 era</li>
      <li>No Sprint races, no fastest lap bonus point</li>
    </ul>

    <h2>Other Seasons</h2>
    <ul>
      <li><a href="/">Current Season Calculator</a></li>
      <li><a href="/2025">2025 F1 Season</a></li>
      <li><a href="/2024">2024 F1 Season</a></li>
      <li><a href="/2023">2023 F1 Season</a></li>
      <li><a href="/2022">2022 F1 Season</a></li>
      <li><a href="/2021">2021 F1 Season</a></li>
      <li><a href="/2020">2020 F1 Season</a></li>
      <li><a href="/2019">2019 F1 Season</a></li>
      <li><a href="/2018">2018 F1 Season</a></li>
      <li><a href="/2017">2017 F1 Season</a></li>
      <li><a href="/2016">2016 F1 Season</a></li>
      <li><a href="/2015">2015 F1 Season</a></li>
      <li><a href="/2014">2014 F1 Season</a></li>
      <li><a href="/2013">2013 F1 Season</a></li>
      <li><a href="/2012">2012 F1 Season</a></li>
      <li><a href="/2011">2011 F1 Season</a></li>
      <li><a href="/2010">2010 F1 Season</a></li>
      <li><a href="/2009">2009 F1 Season</a></li>
      <li><a href="/2008">2008 F1 Season</a></li>
      <li><a href="/2006">2006 F1 Season</a></li>
    </ul>

    <p><a href="/about">FAQ & Help Guide</a></p>

    <p style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #666;">
      Created by <a href="https://chyuang.com">Chyuang</a> |
      <a href="https://github.com/yuyangchee98/F1-Points-Calculator">View on GitHub</a>
    </p>
  </div>

  <AppIsland year="2007" client:only="react" />
  <script is:inline>document.getElementById('seo-content').style.display='none';</script>
</BaseLayout>
