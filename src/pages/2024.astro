---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 2024 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 2024 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 2024 - Championship Predictor"
  description="F1 points calculator for 2024. Predict Formula 1 race results, calculate driver points, and simulate championship standings with our interactive drag-and-drop tool."
  keywords="F1, Formula 1, 2024 season, points calculator, championship predictor, race simulator, F1 standings, predictions"
  canonicalPath="/2024"
  ogTitle="F1 Points Calculator 2024 - Championship Predictor"
  ogDescription="Predict F1 race results and championship standings with our interactive calculator"
  schemaData={schemaData}
  initialYear={2024}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 2024 Season</h1>

    <p>Simulate and predict the 2024 Formula 1 World Championship standings.
    Use our drag-and-drop calculator to place drivers in finishing positions and watch
    the championship table update in real-time.</p>

    <h2>2024 F1 Season Highlights</h2>
    <ul>
      <li>24 races across 21 countries</li>
      <li>6 Sprint race weekends</li>
      <li>Official F1 points system (25-18-15-12-10-8-6-4-2-1)</li>
    </ul>

    <h2>Other Seasons</h2>
    <ul>
      <li><a href="/">Current Season Calculator</a></li>
      <li><a href="/2023">2023 F1 Season</a></li>
      <li><a href="/2022">2022 F1 Season</a></li>
    </ul>

    <p><a href="/about">FAQ & Help Guide</a></p>

    <p style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #666;">
      Created by <a href="https://chyuang.com">Chyuang</a> |
      <a href="https://github.com/yuyangchee98/F1-Points-Calculator">View on GitHub</a>
    </p>
  </div>

  <AppIsland year="2024" client:only="react" />
  <script is:inline>document.getElementById('seo-content').style.display='none';</script>
</BaseLayout>
