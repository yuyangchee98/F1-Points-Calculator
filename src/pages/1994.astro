---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
import SeasonNotesSection from '../components/seo/SeasonNotesSection.astro';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 1994 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 1994 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 1994 - Championship Predictor"
  description="F1 points calculator for 1994. Replay Michael Schumacher's first title and his Adelaide showdown with Damon Hill, in the season forever marked by the loss of Ayrton Senna, with our drag-and-drop simulator."
  keywords="F1, Formula 1, 1994 season, Schumacher, Damon Hill, Senna, Imola, Benetton, Williams, Adelaide, points calculator, championship predictor, race simulator, F1 standings"
  canonicalPath="/1994"
  ogTitle="F1 Points Calculator 1994 - Championship Predictor"
  ogDescription="Replay Schumacher's first title and the Adelaide decider with Damon Hill with our interactive F1 calculator"
  schemaData={schemaData}
  initialYear={1994}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 1994 Season</h1>

    <p>Explore the 1994 Formula 1 World Championship results and simulate alternative
    standings. Use our drag-and-drop calculator to replay Michael Schumacher's controversial
    first title and his title-deciding clash with Damon Hill — in a season forever defined by
    the tragic loss of Ayrton Senna — in the classic 10-6-4-3-2-1 points era.</p>

    <h2>1994 F1 Season Highlights</h2>
    <ul>
      <li>16 races — opening at <strong>Interlagos, Brazil</strong> and closing at <strong>Adelaide, Australia</strong></li>
      <li><strong>Michael Schumacher wins his first World Championship</strong> (92 pts, 8 wins) for Benetton-Ford</li>
      <li><strong>Damon Hill P2</strong> (91 pts) for Williams-Renault — the title decided by just one point at the Adelaide finale, where Schumacher and Hill collided</li>
      <li><strong>Imola tragedy</strong> — the San Marino GP weekend claimed both <strong>Ayrton Senna</strong> and <strong>Roland Ratzenberger</strong>, the sport's darkest weekend and the catalyst for sweeping safety reform</li>
      <li><strong>Gerhard Berger P3</strong> (41 pts) led Ferrari's recovery</li>
      <li><strong>Williams-Renault take the Constructors' Championship</strong> (118 pts to Benetton's 103)</li>
      <li><strong>Schumacher's bans and disqualifications</strong> — he missed two races and was disqualified from others amid controversy, keeping Hill's title hopes alive</li>
      <li><strong>Electronic driver aids banned</strong> — active suspension and traction control outlawed, returning the cars to the drivers</li>
      <li><strong>Classic 10-6-4-3-2-1 points system</strong> — only the top six score</li>
      <li>No Sprint races, no fastest lap bonus point</li>
    </ul>

    <SeasonNotesSection year={1994} />

