---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppIsland from '../components/AppIsland';
import SeasonNotesSection from '../components/seo/SeasonNotesSection.astro';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "F1 Points Calculator 1981 - Championship Predictor",
  "description": "F1 championship calculator and standings predictor. Simulate Formula 1 race results and calculate driver points for the 1981 season.",
  "applicationCategory": "Sports Calculator",
  "operatingSystem": "Web Browser",
  "author": {
    "@type": "Person",
    "name": "Chyuang",
    "url": "https://chyuang.com"
  }
};
---

<BaseLayout
  title="F1 Points Calculator 1981 - Championship Predictor"
  description="F1 points calculator for 1981. Replay Nelson Piquet's first title fought to the wire with Carlos Reutemann, with our drag-and-drop championship simulator."
  keywords="F1, Formula 1, 1981 season, Piquet, Reutemann, Jones, Brabham, Williams, ground effect, points calculator, championship predictor, race simulator, F1 standings"
  canonicalPath="/1981"
  ogTitle="F1 Points Calculator 1981 - Championship Predictor"
  ogDescription="Replay Piquet's first title and the Las Vegas decider with our interactive F1 calculator"
  schemaData={schemaData}
  initialYear={1981}
>
  <!-- SEO content — always in HTML, hidden once React mounts -->
  <div id="seo-content" style="padding: 20px; max-width: 900px; margin: 0 auto; font-family: system-ui, sans-serif; line-height: 1.6;">
    <h1 style="color: #dc2626;">F1 Points Calculator - 1981 Season</h1>

    <p>Explore the 1981 Formula 1 World Championship results and simulate alternative
    standings. Use our drag-and-drop calculator to replay Nelson Piquet's first title,
    decided at the Las Vegas finale, in the classic 9-6-4-3-2-1 ground-effect era where
    only a driver's best 11 results counted.</p>

    <h2>1981 F1 Season Highlights</h2>
    <ul>
      <li>15 races — opening at <strong>Long Beach (US GP West)</strong> and closing at the <strong>Caesars Palace GP, Las Vegas</strong></li>
      <li><strong>Nelson Piquet wins his first World Championship</strong> (50 pts) for Brabham, edging Carlos Reutemann by a single point at the Las Vegas finale</li>
      <li><strong>Carlos Reutemann P2</strong> (49 pts) for Williams — led the standings for much of the year but faded at the final round</li>
      <li><strong>Alan Jones P3</strong> (46 pts), the reigning champion, won the Las Vegas finale in his last Williams race</li>
      <li><strong>Williams take the Constructors' Championship</strong> (95 pts to Brabham's 61), though the Reutemann–Jones team-orders feud overshadowed it</li>
      <li><strong>Carlos Reutemann's Brazil defiance</strong> — ignoring a "Jones–Reutemann" pit board fuelled a season-long intra-team rift</li>
      <li>Peak of the <strong>ground-effect era</strong>, with the controversial "lowering" hydropneumatic suspension to skirt ride-height rules</li>
      <li><strong>Classic 9-6-4-3-2-1 points system</strong> — only the top six score, best 11 results count</li>
      <li>No Sprint races, no fastest lap bonus point</li>
    </ul>

    <SeasonNotesSection year={1981} />

